{
  "name": "sebenv",
  "version": "0.0.7",
  "author": "Yejneshwar Sivamoorthy",
  "repository": {
    "type": "git",
    "url": "https://github.com/Yejneshwar/SebEnv.git"
  },
  "type": "module",
  "description": "CLI tool to ensure environment variables are set.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "rolldown -c",
    "prepublishOnly": "npm run test && npm run build",
    "test": "node --test"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "inquirer": "^9.3.6",
    "sebenv": "file:"
  },
  "bin": {
    "SebEnv": "index.js"
  },
  "license": "AGPL-3.0-only",
  "keywords": [
    "cli",
    "environment",
    "variables",
    "env",
    "envcheck",
    "sebenv"
  ],
  "devDependencies": {
    "rolldown": "^1.0.2"
  }
}